# ── Kortecx Engine Configuration ─────────────────────────────────────────────
# Copy this file to .env and fill in values for your environment.

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database (PostgreSQL — shared with frontend)
DATABASE_URL=postgresql://kortecx:kortecx@localhost:5433/kortecx_dev

# DuckDB (analytical queries — use ":memory:" for ephemeral or a path for persistent)
DUCKDB_PATH=:memory:

# Qdrant (vector store for RAG/embeddings)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kortecx_embeddings

# HuggingFace (optional — can also be set via the Providers UI in the frontend)
HF_TOKEN=

# Apache Spark (data engineering — local mode by default)
SPARK_MASTER=local[*]
SPARK_APP_NAME=kortecx-engine

# Local inference — Ollama
OLLAMA_URL=http://localhost:11434

# Local inference — llama.cpp server
LLAMACPP_URL=http://localhost:8080

# Orchestration
UPLOAD_DIR=./uploads
MAX_CONCURRENT_AGENTS=10
AGENT_RETRY_ENABLED=true
AGENT_FALLBACK_MODEL=llama3.2:3b
DEFAULT_LOCAL_ENGINE=ollama
DEFAULT_LOCAL_MODEL=llama3.1:8b
