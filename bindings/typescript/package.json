{
  "name": "@kortecx/sdk",
  "version": "0.1.0",
  "description": "TypeScript/JavaScript client SDK for the kortecx durable agentic-execution runtime (gRPC + gRPC-web over the frozen KxGateway contract).",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "keywords": ["kortecx", "agentic", "durable", "grpc", "grpc-web", "workflow", "runtime"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js",
      "require": "./dist/web.cjs"
    }
  },
  "sideEffects": false,
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "codegen": "./codegen.sh",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.0",
    "@connectrpc/connect": "^2.0.0",
    "@connectrpc/connect-node": "^2.0.0",
    "@connectrpc/connect-web": "^2.0.0"
  },
  "peerDependencies": {
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@bufbuild/buf": "^1.47.0",
    "@bufbuild/protoc-gen-es": "^2.2.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  },
  "homepage": "https://github.com/Kortecx/kortecx",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kortecx/kortecx.git",
    "directory": "bindings/typescript"
  }
}
