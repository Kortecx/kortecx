# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://kortecx:kortecx@localhost:5433/kortecx_dev
DB_MODE=local

# ─── Qdrant ───────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ─── Engine (Python FastAPI) ──────────────────────────────
ENGINE_HOST=0.0.0.0
ENGINE_PORT=8000

# ─── HuggingFace ─────────────────────────────────────────
# HF_TOKEN=hf_...

# ─── Ollama ──────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
DEFAULT_LOCAL_MODEL=llama3.1:8b

# ─── Frontend ────────────────────────────────────────────
NEXT_PUBLIC_ENGINE_URL=http://localhost:8000
