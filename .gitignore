# ---- Rust ----
# Compiled output
/target/
**/target/

# Backtrace / debug
*.pdb

# Cargo lock is kept for binaries/workspaces; uncomment if this is a library
# Cargo.lock

# rustc incremental / coverage
*.profraw
*.gcda
*.gcno

# proptest failure-persistence artifacts (auto-generated cache; not stable across runs)
**/*.proptest-regressions

# ---- Editor / OS ----
.DS_Store
*.swp
*~
.idea/
.vscode/

# ---- OSS / Cloud split (per `00-vision-and-principles.md` §6) ----
# The OSS workspace (this directory) is the public open-source runtime.
# The cloud-heavy trait impls live in `kx-cloud/` and are PRIVATE — they will
# be developed in their own (separate, private) git repository nested inside
# this subdirectory when P5.5 begins. Until then, the directory holds only a
# stubbed Cargo workspace as an architectural breadcrumb. NEVER commit
# kx-cloud contents to the OSS repo.
kx-cloud/

# ---- Internal docs (kept out of the public OSS repo) ----
# These live in the working tree but never land in `Kortecx/kortecx`. Wildcards
# auto-cover future additions so a new design / suggestion doc doesn't leak by
# accident.
/00-*.md
/01-*.md
/02-*.md
/03-*.md
/04-*.md
/05-*.md
/06-*.md
/07-*.md
/CLAUDE.md
# Local Claude Code agent state (plans, transcripts, settings) — never committed.
/.claude/
/docs/design/*.md
/docs/suggestions/*.md
# Internal analysis / feasibility reviews — private-only (docs default to private).
/docs/analysis/
# Plan files are private-only (SN-5: plans NEVER land in the public OSS repo).
/docs/plans/
# Profiling/benchmark results are private-only (Golden Rule 10 / SN-2): the
# `just profile` HARNESS is public OSS, but the captured numbers are a corpus
# trend record that lives only in the private kortecx-core checkout under
# docs/benchmarks/. Added BEFORE any result file can exist so none leaks.
/docs/benchmarks/
# Internal warning/debug log — kept in the private kortecx-core repo only.
/WARNINGS.md

# ---- Docker compose dev secrets ----
# Only the *.example templates are committed. A developer may copy them to the
# un-suffixed names below (or replace them) for local customization; the real
# secret files never land in git.
/deploy/secrets/kx_authtokens
/deploy/secrets/kx_token
